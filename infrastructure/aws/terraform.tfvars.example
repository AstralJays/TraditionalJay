# Copy to terraform.tfvars (gitignored) and fill in.
# Never commit real Upwind credentials.

aws_region      = "us-east-1"
# Always Surfshop — do not use the default/Perkins profile.
aws_profile     = "surfshop"
name_prefix     = "traditionaljay"
instance_type   = "t3.large"
root_volume_gb  = 30

# Upwind host sensor — installed on first boot when both are set.
# Use the same client ID/secret as JaysSurfShop if you want one Upwind org view.
upwind_client_id           = "YOUR_UPWIND_CLIENT_ID"
upwind_client_secret       = "YOUR_UPWIND_CLIENT_SECRET"
upwind_agent_extra_config  = "scanner-v2=true"
